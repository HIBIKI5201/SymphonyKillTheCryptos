    - rid: 6921726254923645111
  - _name: 
    _text: "1991\u5E7411\u6708\u2500\u2500\u2500 "
    _isWaitForInput: 1
    _scenarioActions: []
  - _name: 
    _text: "\u30C1\u30A7\u30C1\u30A7\u30F3\u306B\u3066\u5143\u30BD\u9023\u8ECD\u5C06\u8ECD
      \n\u30B8\u30E7\u30CF\u30EB\u30FB\u30C9\u30A5\u30C0\u30A8\u30D5\u304C\u5927\u7D71\u9818\u306B\u5C31\u4EFB\u3002 "
    _isWaitForInput: 1
    _scenarioActions: []
  - _name: 
    _text: "\u30BD\u30F4\u30A3\u30A8\u30C8\u9023\u90A6\u96E2\u8131\u6CD5\u3092\u57FA\u306B\u4E00\u65B9\u7684\u306B\u72EC\u7ACB\u3092\u5BA3\u8A00\u3002
      \n\u30ED\u30B7\u30A2\u6B63\u6559\u3092\u653E\u68C4\u3059\u308B\u306A\u3069\u8131\u30ED\u30B7\u30A2\u5316\u3092\u63A8\u3057\u9032\u3081\u308B\u3002 "
    _isWaitForInput: 1
    _scenarioActions: []
  - _name: 
    _text: "\u305D\u308C\u3092\u53D7\u3051\u30ED\u30B7\u30A2\u306F\u6CBB\u5B89\u7DAD\u6301\u90E8\u968A\u3092\u6D3E\u9063\u3059\u308B\u304C
      \n\u4E88\u60F3\u5916\u306E\u62B5\u6297\u306B\u64A4\u9000\u3092\u4F59\u5100\u306A\u304F\u3055\u308C"
    _isWaitForInput: 1
    _scenarioActions: []
  - _name: 
    _text: "1994\u5E7412\u6708\u3001\u30ED\u30B7\u30A2\u306F\u30C1\u30A7\u30C1\u30A7\u30F3\u3078\u672C\u683C\u7684\u306A
      \n\u6B66\u529B\u884C\u4F7F\u3092\u958B\u59CB\u3002\u30C1\u30A7\u30C1\u30A7\u30F3\u3078\u306E\u8ECD\u4E8B\u884C\u52D5\u3092\u8D77\u3053\u3059\u3002 "
    _isWaitForInput: 1
    _scenarioActions: []
  - _name: 
    _text: "\u3053\u308C\u306B\u5BFE\u3057\u30C1\u30A7\u30C1\u30A7\u30F3\u5074\u306F\u30AA\u30DE\u30EB\u30FB\u30CF\u30C3\u30C0\u30FC\u30C9\u3092\u53F8\u4EE4\u5B98
      \n\u3068\u3057\u53CD\u6483\u3092\u958B\u59CB\u3002\u30ED\u30B7\u30A2\u8ECD\u3092\u76F8\u624B\u306B\u596E\u95D8\u3059\u308B\u3002 "
    _isWaitForInput: 1
    _scenarioActions: []
  - _name: 
    _text: "\u3055\u3089\u306B\u306F\u3053\u306E\u6226\u3044\u3092\u30B8\u30CF\u30FC\u30C9\uFF08\u8056\u6226\uFF09\u3068\u79F0\u3057\u305F
      \n\u30E0\u30B8\u30E3\u30D2\u30C7\u30A3\u30F3\u3082\u53C2\u6226\u3057\u3001\u6226\u5C40\u306F\u6CE5\u6CBC\u3068\u5316\u3057\u3066\u3044\u305F\u3002 "
    _isWaitForInput: 1
    _scenarioActions: []
  - _name: 
    _text: "1994\u5E7412\u6708 \u30B0\u30ED\u30BA\u30CC\u30A4\u90CA\u5916 \u30A6\u30EB\u30B9\u30FB\u30DE\u30EB\u30BF\u30F3\u8FD1\u90CA
      \n"
    _isWaitForInput: 1
    _scenarioActions:
    - rid: 6921726254923645112
  - _name: Triad
    _text: "Symphony\u2500\u2500\u2500 \n\u72B6\u6CC1\u3092\u5831\u544A\u3057\u3066\u304F\u308C"
    _isWaitForInput: 1
    _scenarioActions: []
  - _name: Symphony
    _text: "\u3053\u3061\u3089Symphony\u3002 \n\u2026\u30B0\u30ED\u30BA\u30CC\u30A4\u5E02\u8857\u5730\u304B\u3089\u96E2\u8131\u3002 "
    _isWaitForInput: 1
    _scenarioActions:
    - rid: 6921726254923645113
  - _name: Triad
    _text: "\u3088\u3057\u3001\u305D\u306E\u307E\u307E\u30A6\u30EB\u30B9\u30FB\u30DE\u30EB\u30BF\u30F3\u65B9\u9762\u306B
      \n\u5411\u304B\u3044\u6226\u8ECA\u90E8\u968A\u306B\u63A5\u89E6\u3057\u3066\u304F\u308C\u3002 "
    _isWaitForInput: 1
    _scenarioActions:
    - rid: 6921726254923645114
    - rid: 6921726254923645115
  - _name: Symphony
    _text: "Prelude\u306F\u3069\u3046\u306A\u3063\u305F\u306E\uFF1F "
    _isWaitForInput: 1
    _scenarioActions: []
  - _name: Triad
    _text: "Prelude\u306F\u6226\u8ECA\u90E8\u968A\u304B\u3089\u96E2\u8131\u5F8C \n\u6226\u7DDA\u3092\u96E2\u8131\u3001\u4FFA\u305F\u3061\u3068\u5408\u6D41\u3057\u3066\u2500\u2500 "
    _isWaitForInput: 1
    _scenarioActions: []
  - _name: Prelude
    _text: "\u3053\u306E\u901A\u308A\u3001Triad\u306E\u96A3\u306B\u3044\u308B\u3088\u3002 "
    _isWaitForInput: 1
    _scenarioActions: []
  - _name: Triad
    _text: "\u2026\u8074\u3044\u3066\u306E\u901A\u308A\u7121\u4E8B\u3060\u3002 \n\u3068\u306B\u304B\u304F\u3001\u4ECA\u306F\u4F5C\u6226\u306B\u96C6\u4E2D\u3057\u3066\u304F\u308C\u3002 "
    _isWaitForInput: 1
    _scenarioActions: []
  - _name: Symphony
    _text: "\u4E86\u89E3\u2026\u3002\u884C\u52D5\u3092\u958B\u59CB\u3059\u308B\u3002 "
    _isWaitForInput: 1
    _scenarioActions: []
